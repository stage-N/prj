---
layout: blog-base.njk
---
<article class="blog-article blog-container">
  <header>
    <time datetime="{{ date | isoDate }}">{{ date | blogDateJa }}</time>
    <h1>{{ title }}</h1>
    {% if tags and tags.length %}
    <ul class="blog-tags">
      {% for tag in tags %}
      <li>{{ tag }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </header>
  <div class="blog-body">
    {{ content }}
  </div>
</article>
